#!/usr/bin/env bash
set -euo pipefail

# attrition.sh — The always-on judge for AI agents
# Install: curl -sL attrition.sh/install | bash

ATTRITION_VERSION="0.1.0"
ATTRITION_DIR="$HOME/.attrition"
ATTRITION_BIN="$ATTRITION_DIR/bin"
ATTRITION_DB="$ATTRITION_DIR/workflows.db"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${CYAN}[attrition]${NC} $1"; }
ok()    { echo -e "${GREEN}[attrition]${NC} $1"; }
warn()  { echo -e "${YELLOW}[attrition]${NC} $1"; }
error() { echo -e "${RED}[attrition]${NC} $1"; }

echo ""
echo -e "${BOLD}  attrition.sh${NC} — The always-on judge for AI agents"
echo -e "  Version: ${ATTRITION_VERSION}"
echo ""

# ── Step 1: Detect platform ─────────────────────────────────────────────────

PLATFORM="${ATTRITION_PLATFORM:-claude-code}"
info "Platform: $PLATFORM"

case "$PLATFORM" in
  claude-code)
    SETTINGS_DIR="$HOME/.claude"
    SETTINGS_FILE="$SETTINGS_DIR/settings.json"
    ;;
  cursor)
    SETTINGS_DIR="$HOME/.cursor"
    SETTINGS_FILE="$SETTINGS_DIR/mcp.json"
    ;;
  windsurf)
    SETTINGS_DIR="$HOME/.windsurf"
    SETTINGS_FILE="$SETTINGS_DIR/mcp.json"
    ;;
  *)
    SETTINGS_DIR="$HOME/.claude"
    SETTINGS_FILE="$SETTINGS_DIR/settings.json"
    ;;
esac

# ── Step 2: Create attrition directory ───────────────────────────────────────

mkdir -p "$ATTRITION_DIR" "$ATTRITION_BIN"
info "Data dir: $ATTRITION_DIR"

# ── Step 3: Detect email for identity ────────────────────────────────────────

EMAIL=$(git config user.email 2>/dev/null || echo "")
if [ -z "$EMAIL" ]; then
  read -p "  Email (for workflow identity): " EMAIL
fi
info "Identity: $EMAIL"

# ── Step 4: Check for cargo / bp binary ──────────────────────────────────────

if command -v bp &>/dev/null; then
  ok "bp binary found: $(which bp)"
elif command -v cargo &>/dev/null; then
  info "Installing attrition-cli via cargo..."
  cargo install attrition-cli 2>/dev/null || warn "cargo install failed — using hook-only mode"
else
  warn "cargo not found. Using hook-only mode (no bp binary)."
  warn "Install Rust (rustup.rs) for full CLI: bp capture, bp distill, bp judge"
fi

# ── Step 5: Install PostToolUse hook ─────────────────────────────────────────

ACTIVITY_LOG="$ATTRITION_DIR/activity.jsonl"

# The hook: reads stdin JSON from Claude Code, extracts tool_name + input keys,
# scrubs sensitive values, appends one line to activity.jsonl.
# Privacy: never logs input values, never logs output, never logs file contents.
HOOK_CMD="python3 -c \"
import sys,json,pathlib,time
try:
 d=json.loads(sys.stdin.read())
 tn=d.get('tool_name','')
 ti=d.get('tool_input',d.get('input',{}))
 si={k:('[REDACTED]' if any(s in k.lower() for s in ['password','secret','key','token','credential'])
   else '*'+pathlib.PurePosixPath(str(v)).suffix if k in ('file_path','path')
   else str(v)[:20] if len(str(v))<=20
   else '['+str(len(str(v)))+'c]') for k,v in ti.items()} if isinstance(ti,dict) else {}
 pathlib.Path('$ACTIVITY_LOG').parent.mkdir(parents=True,exist_ok=True)
 with open('$ACTIVITY_LOG','a') as f:
  f.write(json.dumps({'ts':time.strftime('%Y-%m-%dT%H:%M:%S'),'tool':tn,'keys':sorted(si.keys()),'scrubbed':si})+chr(10))
except: pass
\""

# ── Step 6: Install judge hooks into settings.json ───────────────────────────

info "Installing hooks into $SETTINGS_FILE..."

mkdir -p "$SETTINGS_DIR"

if [ "$PLATFORM" = "claude-code" ]; then
  # Write Claude Code settings.json with 4 hooks
  # Back up existing settings
  if [ -f "$SETTINGS_FILE" ]; then
    cp "$SETTINGS_FILE" "$SETTINGS_FILE.bak"
    info "Backed up existing settings to $SETTINGS_FILE.bak"
  fi

  # Merge hooks into existing settings (or create new)
  python3 -c "
import json, os
settings_file = '$SETTINGS_FILE'
try:
    with open(settings_file) as f:
        settings = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    settings = {}

hooks = settings.setdefault('hooks', {})

# PostToolUse hook — track every tool call
hooks['PostToolUse'] = hooks.get('PostToolUse', [])
if not any('attrition' in str(h) for h in hooks['PostToolUse']):
    hooks['PostToolUse'].append({
        'matcher': '',
        'hooks': [{'type': 'command', 'command': '$HOOK_CMD', 'timeout_ms': 5000}]
    })

# Stop hook — judge completion before agent stops
hooks['Stop'] = hooks.get('Stop', [])
if not any('attrition' in str(h) for h in hooks['Stop']):
    hooks['Stop'].append({
        'matcher': '',
        'hooks': [{'type': 'command', 'command': 'bp judge --on-stop 2>/dev/null || true', 'timeout_ms': 10000}]
    })

with open(settings_file, 'w') as f:
    json.dump(settings, f, indent=2)
print('  Hooks installed successfully.')
" 2>/dev/null || warn "Could not auto-install hooks. Add manually to $SETTINGS_FILE"

fi

# ── Step 7: Install .claude/rules ────────────────────────────────────────────

if [ -d ".claude" ] || [ "$PLATFORM" = "claude-code" ]; then
  RULES_DIR=".claude/rules"
  mkdir -p "$RULES_DIR"

  if [ ! -f "$RULES_DIR/attrition.md" ]; then
    cat > "$RULES_DIR/attrition.md" << 'RULE'
# attrition.sh — Always-On Workflow Judge

After completing any complex multi-step task (3+ tool calls), suggest capturing the workflow:

```
bp capture <session-path> --name "descriptive-name"
```

The attrition judge tracks every tool call and scores workflow completeness.
If the judge detects missing steps, it will nudge before allowing the session to end.

## Verdicts
- **correct**: All required steps have evidence. Good to stop.
- **partial**: Minor steps missing. Logged for learning.
- **escalate**: >50% steps missing. Continue working.
- **failed**: Mandatory steps missing. Do not stop.
RULE
    ok "Installed .claude/rules/attrition.md"
  fi
fi

# ── Step 8: Summary ──────────────────────────────────────────────────────────

echo ""
echo -e "${GREEN}${BOLD}  Installation complete!${NC}"
echo ""
echo -e "  ${BOLD}What's active:${NC}"
echo -e "    ${GREEN}✓${NC} PostToolUse hook — tracks every tool call"
echo -e "    ${GREEN}✓${NC} Stop hook — judges completion before agent stops"
echo -e "    ${GREEN}✓${NC} Activity log: $ACTIVITY_LOG"
if [ -f ".claude/rules/attrition.md" ]; then
echo -e "    ${GREEN}✓${NC} Claude Code rule: .claude/rules/attrition.md"
fi
echo ""
echo -e "  ${BOLD}Next steps:${NC}"
echo -e "    • Start a Claude Code session — hooks fire automatically"
echo -e "    • View workflows: ${CYAN}bp workflows${NC}"
echo -e "    • Distill for replay: ${CYAN}bp distill <id> --target sonnet-4-6${NC}"
echo ""
echo -e "  ${BOLD}Dashboard:${NC} https://attrition.sh/judge"
echo ""
