daas/results/workflow_specs.json
daas/results/replays.json
daas/results/judgments.json
daas/results/*.log
# Cluster / playbook / replay raw artifacts include session text that may
# embed API keys pasted into prompts. Only the `*_public.json` aggregates
# and `corpus_public.json` are safe to commit.
